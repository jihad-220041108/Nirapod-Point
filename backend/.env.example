# Application Settings
APP_NAME=NirapodPoint
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database Configuration
POSTGRES_USER=nirapodpoint_user
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=nirapodpoint_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# PostGIS Extension (automatically enabled)
ENABLE_POSTGIS=True

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Celery Configuration
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/0

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000
ALLOWED_METHODS=*
ALLOWED_HEADERS=*

# SMS Gateway - CloudWaveBD
CLOUDWAVEBD_API_KEY=your-cloudwavebd-api-key
CLOUDWAVEBD_SENDER_ID=NirapodPoint
CLOUDWAVEBD_API_URL=https://api.cloudwavebd.com/sms/send

# Twilio (Backup SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# AWS S3 / Cloud Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=nirapodpoint-media
S3_VIDEO_BUCKET=nirapodpoint-sos-videos

# Google Maps API (Optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Cloud AI Services
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
GOOGLE_CLOUD_CREDENTIALS_PATH=./google-cloud-credentials.json
GOOGLE_CLOUD_REGION=us-central1

# Speech-to-Text Settings
SPEECH_RECOGNITION_LANGUAGE=en-US
SPEECH_MAX_DURATION_SECONDS=30
SPEECH_SAMPLE_RATE=16000

# OSRM Routing Server
OSRM_BASE_URL=http://localhost:5000

# Crime Score Calculation
CRIME_SCORE_UPDATE_INTERVAL=1800  # 30 minutes in seconds
CRIME_ZONE_GRID_SIZE=500  # meters
CRIME_TIME_DECAY_DAYS=90  # How many days to consider for scoring

# Geofencing
DANGER_ZONE_THRESHOLD=75  # Crime score above this triggers alert
LOCATION_UPDATE_INTERVAL=60  # seconds

# SOS Settings
SOS_VIDEO_MAX_DURATION=300  # 5 minutes in seconds
SOS_VIDEO_MAX_SIZE_MB=100
EMERGENCY_RESPONSE_RADIUS_KM=10  # Search radius for nearest police station

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Monitoring
SENTRY_DSN=your-sentry-dsn-for-error-tracking
